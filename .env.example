# Copiá a `.env` en la raíz del repo (mismo directorio que docker-compose.yml).
# Valores de ejemplo: reemplazá por los reales (Neon, JWT, Anthropic, etc.).

# --- PostgreSQL (Neon) ---
# Connection string típico del dashboard Neon (requiere SSL):
DATABASE_URL=postgresql://NEON_USER:NEON_PASSWORD@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# El backend ATV (Pony + parches psycopg2) usa estas variables vía python-decouple.
# Podés rellenarlas a mano o derivarlas del string de Neon.
DB_PROVIDER=postgres
DB_USER=NEON_USER
DB_PASS=NEON_PASSWORD
DB_HOST=ep-example-123456.us-east-2.aws.neon.tech
DB_NAME=neondb
# Obligatorio para Neon:
DB_SSLMODE=require

SECRET=genera_un_secreto_largo_para_jwt

# --- Anthropic ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# --- Frontend (build-time Vite; usá la URL pública de la API detrás de nginx) ---
VITE_API_BASE_URL=https://api.tu-dominio.com

# --- Puertos publicados (opcional) ---
BACKEND_PUBLISH_PORT=8000
FRONTEND_PUBLISH_PORT=80
